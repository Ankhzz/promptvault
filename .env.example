# ── Privy Auth ──
# Required. Get from https://dashboard.privy.io → Settings → App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# Required. Get from https://dashboard.privy.io → Settings → API Keys → App Secret
PRIVY_APP_SECRET=

# ── Story Protocol (Aeneid Testnet) ──
# Default values for Aeneid; change if deploying to another network
NEXT_PUBLIC_STORY_RPC_URL=https://aeneid.storyrpc.io
NEXT_PUBLIC_STORY_CHAIN_ID=1315
NEXT_PUBLIC_STORY_EXPLORER=https://aeneid.storyscan.xyz

# CometBFT RPC endpoint for CDR SDK
# Production: must use HTTPS (e.g. https://comet-proxy.example.com:26657)
# Dev: defaults to http://172.192.41.96:26657 if not set
NEXT_PUBLIC_COMET_RPC_URL=

# ── Database (Supabase PostgreSQL) ──
# Required. Direct PostgreSQL connection string via Supabase pooler.
# Example: postgresql://postgres.<project>.supabase.co:6543/postgres?pgbouncer=true
DATABASE_URL=

# ── MUSDC & Marketplace Contracts ──
# Deployed contract addresses on Story Aeneid
NEXT_PUBLIC_MUSDC_TOKEN_ADDRESS=
NEXT_PUBLIC_MARKETPLACE_ADDRESS=

# ── Faucet Wallet ──
# EOA private key for the faucet wallet (funded with MUSDC + IP for claims)
# Server-side only. Never prefix with NEXT_PUBLIC_.
MUSDC_FAUCET_ADDRESS=
MUSDC_FAUCET_PRIVATE_KEY=

# ── Lighthouse IPFS ──
# API key for file uploads to Lighthouse.storage
# Server-side only. Never prefix with NEXT_PUBLIC_.
LIGHTHOUSE_API_KEY=

# ── Test Routes ──
# Set to "true" to enable /test, /test-cdr, /test-cdr-flow (disabled in production by default)
NEXT_PUBLIC_ENABLE_TEST_ROUTES=false